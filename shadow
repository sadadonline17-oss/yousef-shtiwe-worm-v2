#!/usr/bin/env python3
import sys
import os
import subprocess

# Absolute path resolution
BASE_DIR = os.path.dirname(os.path.abspath(__file__))
sys.path.insert(0, BASE_DIR)

def check_and_install_deps():
    try:
        import fire
        import nexttoken
        import requests
        import rich
        import prompt_toolkit
    except ImportError:
        print("🛠️ [SHADOW-BOOT] Core dependencies missing. Attempting self-healing...")
        
        # Check for pip, try to install it if missing
        try:
            subprocess.check_call([sys.executable, "-m", "pip", "--version"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        except subprocess.CalledProcessError:
            print("📦 [SHADOW-BOOT] 'pip' not found in environment. Bootstrapping via ensurepip...")
            try:
                subprocess.check_call([sys.executable, "-m", "ensurepip", "--upgrade"])
            except Exception as e:
                print(f"❌ [SHADOW-BOOT] ensurepip failed: {e}. Please install pip manually.")
                sys.exit(1)
        
        # Install dependencies
        print("🛠️ [SHADOW-BOOT] Injecting missing modules: fire, nexttoken, requests, rich, prompt_toolkit...")
        try:
            subprocess.check_call([sys.executable, "-m", "pip", "install", "--upgrade", "pip"])
            subprocess.check_call([sys.executable, "-m", "pip", "install", "fire", "nexttoken", "requests", "rich", "prompt_toolkit", "aiohttp", "croniter"])
            print("✅ [SHADOW-BOOT] Injection successful. Restarting Shadow...")
            os.execv(sys.executable, [sys.executable] + sys.argv)
        except Exception as e:
            print(f"❌ [SHADOW-BOOT] Injection failed: {e}")
            sys.exit(1)

if __name__ == "__main__":
    check_and_install_deps()
    try:
        from shadow_cli.main import main
        main()
    except Exception as e:
        print(f"❌ [SHADOW-CRASH] Shadow encountered a fatal error during startup: {e}")
        sys.exit(1)
