#!/usr/bin/env python3
import sys
import os
import subprocess

# Absolute path resolution
BASE_DIR = os.path.dirname(os.path.abspath(__file__))
sys.path.insert(0, BASE_DIR)

def check_and_install_deps():
    try:
        import fire
        import nexttoken
        import requests
    except ImportError:
        print("🛠️ [SHADOW-BOOT] Missing core dependencies. Injecting now...")
        subprocess.check_call([sys.executable, "-m", "pip", "install", "fire", "nexttoken", "requests", "rich", "prompt_toolkit"])
        print("✅ [SHADOW-BOOT] Injection successful. Restarting...")
        os.execv(sys.executable, ['python3'] + sys.argv)

if __name__ == "__main__":
    check_and_install_deps()
    from shadow_cli.main import main
    main()
